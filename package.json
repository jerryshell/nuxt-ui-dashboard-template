{
  "name": "nuxt-ui-dashboard-template",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "typecheck": "nuxt typecheck",
    "build:bun": "bun --bun nuxt build",
    "compile": "bun build .output/server/index.mjs --compile --outfile nuxtbin",
    "compile:linux": "bun build .output/server/index.mjs --compile --outfile nuxtbin-linux --target bun-linux-x64",
    "compile:linux-musl": "bun build .output/server/index.mjs --compile --outfile nuxtbin-linux-musl --target bun-linux-x64-musl",
    "build:bin": "bun run build:bun && bun run compile",
    "build:bin:linux": "bun run build:bun && bun run compile:linux",
    "build:bin:linux-musl": "bun run build:bun && bun run compile:linux-musl",
    "start:bin": "./nuxtbin"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.119",
    "@internationalized/date": "^3.12.2",
    "@nuxt/ui": "^4.10.0",
    "@tanstack/table-core": "^8.21.3",
    "@unovis/vue": "^1.6.7",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "tailwindcss": "^4.3.3",
    "vue-tsc": "^3.3.8"
  },
  "overrides": {
    "@unhead/vue": "3.2.1",
    "unhead": "3.2.1"
  }
}
